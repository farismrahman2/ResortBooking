# Supabase — get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — only used server-side, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cron secret — protects scheduled jobs (e.g. the daily corporate snapshot).
# Set the SAME value in Vercel → Project → Settings → Environment Variables.
# Vercel Cron automatically sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=generate_a_long_random_string_here

# Enquiry ingest secret — protects POST /api/enquiries, the endpoint the public
# marketing website (garden-centre-resort) calls to push each new lead into the
# back-office. Set the SAME value here and as RESORT_AGENT_ENQUIRY_SECRET on the
# public site. Callers must send `Authorization: Bearer <ENQUIRY_INGEST_SECRET>`.
ENQUIRY_INGEST_SECRET=generate_a_long_random_string_here

# ─── Authentication setup ────────────────────────────────────────────────────
# Users are created manually in Supabase Dashboard → Authentication → Users.
# Steps (one-time):
#   1. Dashboard → Authentication → Providers → Email: enabled (on by default)
#   2. Dashboard → Authentication → Settings → "Confirm email": OFF
#      (since admins create accounts directly, no email confirmation needed)
#   3. Dashboard → Authentication → Users → "Add user" → "Create new user"
#      Enter email and password. Users can now log in at /login.
#   4. Dashboard → Authentication → URL Configuration → Site URL:
#      Set to https://your-vercel-domain.vercel.app
